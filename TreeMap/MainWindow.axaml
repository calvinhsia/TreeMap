<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TreeMap.MainWindow"
        Title="TreeMap (Avalonia)"
        Width="1000" Height="700"
        Background="#FFFFFFFF">
    <Grid RowDefinitions="Auto,*">
        <StackPanel Orientation="Horizontal" Margin="8" Grid.Row="0">
            <TextBox Name="PathBox" Width="480" Watermark="Enter folder path or click Browse" />
            <Button Name="BrowseBtn" Content="Browse" Margin="8,0,0,0" />
            <Button Name="ScanBtn" Content="Scan" Margin="8,0,0,0" />
            <TextBlock Name="StatusText" Margin="12,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="350,*">
            <ContentControl Name="LeftHost" Grid.Column="0" Background="#FFF8F8F8" />
            <Border Name="TreeCanvasHost" Grid.Column="1" Background="#FFFFFFFF" ClipToBounds="True">
                <Canvas Name="TreeCanvas" />
            </Border>
        </Grid>
    </Grid>
</Window>
